function parseSseData(raw) {
    if (raw == null || raw === '') return '';
    try { return JSON.parse(raw); } catch (e) { return raw; }
}

function dispatchSseEvent(eventName, payload, streamState) {
    if (eventName === 'token') {
        const token = typeof payload === 'string' ? payload : '';
        streamState.buffer += token;
        streamState.bubble.textContent = streamState.buffer;
        return;
    }
    if (eventName === 'done') {
        const done = typeof payload === 'object' && payload !== null ? payload : { text: String(payload || '') };
        const text = (done.text || streamState.buffer || '').trim();
        streamState.buffer = text;
        streamState.bubble.textContent = text;
        clarificationHistory.push({ role: 'assistant', content: text });
        clarificationReady = Boolean(done.ready);
        setClarificationStreamingState(false);
        if (clarificationReady) {
            addLog('š│╗š╗č', 'ÚťÇŠ▒éŠżäŠŞůň«îŠłÉ´╝îňĆ»ń╗ąň╝ÇňžőÚťÇŠ▒éňłćŠ×ÉŃÇé', 'success');
        }
        return;
    }
    if (eventName === 'error') {
        const msg = typeof payload === 'object' && payload !== null ? (payload.message || 'ňęóňőČšź╗šĺçÚöőšť░ŠżÂŔżźŔžŽ') : String(payload || 'ňęóňőČšź╗šĺçÚöőšť░ŠżÂŔżźŔžŽ');
        throw new Error(msg);
    }
}

function handleSseChunk(chunk, streamState) {
    streamState.raw += chunk.replace(/\r/g, '');
    let idx = streamState.raw.indexOf('\n\n');
    while (idx >= 0) {
        const block = streamState.raw.slice(0, idx);
        streamState.raw = streamState.raw.slice(idx + 2);
        let eventName = 'message';
        const dataLines = [];
        for (const line of block.split('\n')) {
            if (line.startsWith('event:')) eventName = line.slice(6).trim();
            else if (line.startsWith('data:')) dataLines.push(line.slice(5).trim());
        }
        dispatchSseEvent(eventName, parseSseData(dataLines.join('\n')), streamState);
        idx = streamState.raw.indexOf('\n\n');
    }
}

