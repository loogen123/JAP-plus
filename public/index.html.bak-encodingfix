function buildPreviewUrl(path) {
    const normalized = String(path || '').replace(/\\/g, '/');
    return API_BASE + '/api/v1/preview/' + encodeURI(normalized);
}

async function hydrateWorkspaceFile(path) {
    if (!path) return;
    try {
        const resp = await fetch(buildPreviewUrl(path));
        if (!resp.ok) return;
        const contentType = resp.headers.get('content-type') || '';
        if (contentType.includes('text') || contentType.includes('json') || contentType.includes('xml') || contentType.includes('yaml') || contentType.includes('javascript')) {
            const text = await resp.text();
            workspaceFiles[path] = text;
            if (document.getElementById('previewFileName').textContent === path) {
                selectFile(path);
            }
        }
    } catch (_) {
    }
}

async function syncTaskFileList(taskId) {
    if (!taskId) return;
    try {
        const resp = await fetch(API_BASE + '/api/v1/tasks/' + encodeURIComponent(taskId) + '/files');
        if (!resp.ok) return;
        const data = await resp.json();
        const flat = [];
        const walk = (nodes) => {
            (nodes || []).forEach(n => {
                if (n && n.children && Array.isArray(n.children) && n.children.length > 0) {
                    walk(n.children);
                } else if (n && n.path) {
                    flat.push(n.path);
                }
            });
        };
        walk(data.files);
        flat.forEach(path => {
            if (!workspaceFiles[path]) {
                workspaceFiles[path] = `// ÚÉóšćŞň×ÜÚÉĘňőČŠ×âŠÁá? ${path}\n// ÚŹÉňĹşţćÉÚŹöšŐ║ŠÁçŠÂô?..`;
                hydrateWorkspaceFile(path);
            }
        });
        renderFileTree(workspaceFiles);
    } catch (_) {
    }
}

