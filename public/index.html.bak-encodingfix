function renderMarkdown(md) {
    let html = escapeHtml(md);
    
    html = html.replace(/^### (.+)$/gm, '<h3 class="text-base font-bold text-[--text-primary] mt-4 mb-2">$1</h3>');
    html = html.replace(/^## (.+)$/gm, '<h2 class="text-lg font-bold text-[--text-primary] mt-4 mb-2">$1</h2>');
    html = html.replace(/^# (.+)$/gm, '<h1 class="text-xl font-bold text-[--text-primary] mt-4 mb-3 pb-2 border-b border-[--border-color]">$1</h1>');
    
    html = html.replace(/\*\*(.+?)\*\*/g, '<strong class="text-[--text-primary]">$1</strong>');
    html = html.replace(/\*(.+?)\*/g, '<em>$1</em>');
    html = html.replace(/`(.+?)`/g, '<code class="bg-[--bg-secondary] px-1 rounded text-[--accent-cyan]">$1</code>');
    
    html = html.replace(/^- (.+)$/gm, '<li class="ml-4 text-[--text-secondary]">$1</li>');
    html = html.replace(/^(\d+)\. (.+)$/gm, '<li class="ml-4 text-[--text-secondary]">$2</li>');
    
    html = html.replace(/```(\w+)?\n([\s\S]*?)```/g, function(match, lang, code) {
        return '<pre class="bg-[--bg-secondary] p-3 rounded-lg my-2 overflow-auto text-xs"><code>' + code.trim() + '</code></pre>';
    });
    
    html = html.replace(/\n\n/g, '</p><p class="my-2 text-[--text-secondary]">');
    html = '<p class="my-2 text-[--text-secondary]">' + html + '</p>';
    
    return html;
}

function highlightJava(code, filename) {
    if (!filename?.endsWith('.java')) return escapeHtml(code);
    const lines = code.split('\n');
    return lines.map((line, i) => {
        let escaped = escapeHtml(line);
        escaped = escaped.replace(/\b(public|private|protected|class|interface|enum|import|package|return|new|void|int|String|boolean|long|List|Set|Map|Optional)\b/g, '<span style="color:#c084fc">$1</span>');
        escaped = escaped.replace(/\b(@\w+)\b/g, '<span style="color:#fbbf24">$1</span>');
        escaped = escaped.replace(/(\/\/.*$)/g, '<span style="color:#64748b">$1</span>');
        escaped = escaped.replace(/(".+?")/g, '<span style="color:#34d399">$1</span>');
        return `<div class="code-line flex"><span class="inline-block w-8 text-right mr-3 text-[--text-muted] select-none">${i+1}</span><span>${escaped || '&nbsp;'}</span></div>`;
    }).join('');
}

