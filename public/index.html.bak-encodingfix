async function saveFileToDirectory(filePath, content) {
    if (!workspaceDirectoryHandle) {
        console.warn('ÚĆłţüłÔéČňĄőňźĘÚÉęţć╝šÂŹÚöŤň▒żŠúĄňĘëŠŤÜš╣ÜšÇŤŠĘ╗Š×âŠÁá?', filePath);
        return false;
    }
    
    try {
        const pathParts = filePath.split('/');
        let currentDir = workspaceDirectoryHandle;
        
        for (let i = 0; i < pathParts.length - 1; i++) {
            const part = pathParts[i];
            try {
                currentDir = await currentDir.getDirectoryHandle(part, { create: true });
            } catch {
                currentDir = await currentDir.getDirectoryHandle(part, { create: true });
            }
        }
        
        const fileName = pathParts[pathParts.length - 1];
        const fileHandle = await currentDir.getFileHandle(fileName, { create: true });
        const writable = await fileHandle.createWritable();
        await writable.write(content);
        await writable.close();
        
        return true;
    } catch (err) {
        console.error('ŠĚçŠ┐ćšôĘÚĆéňŤŽŠČóŠżÂŔżźŔžŽ:', filePath, err);
        return false;
    }
}

function onFolderSelected(event) {
    const files = event.target.files;
    if (files && files.length > 0) {
        const firstFile = files[0];
        const relativePath = firstFile.webkitRelativePath || firstFile.name;
        
        if (relativePath) {
            const pathParts = relativePath.split('/');
            const selectedFolder = pathParts[0];
            
            const statusEl = document.getElementById('workspaceStatus');
            statusEl.textContent = 'ň«ŞŠčąÔéČňĄőňźĘÚĆéňŤŽŠČóŠżÂ? ' + selectedFolder;
            statusEl.className = 'text-xs text-green-400 mt-1';
            
            const pathInput = document.getElementById('workspacePath');
            const currentValue = pathInput.value;
            
            if (currentValue && currentValue.includes('/')) {
                const lastSlash = currentValue.lastIndexOf('/');
                const basePath = currentValue.substring(0, lastSlash);
                pathInput.value = basePath + '/' + selectedFolder;
            } else if (currentValue && currentValue.includes('\\')) {
                const lastSlash = currentValue.lastIndexOf('\\');
                const basePath = currentValue.substring(0, lastSlash);
                pathInput.value = basePath + '\\' + selectedFolder;
            } else {
