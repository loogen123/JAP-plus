async function loadSettings() {
    try {
        const response = await fetch(API_BASE + '/api/v1/config');
        if (response.ok) {
            const data = await response.json();
            const defaultBaseUrl = data?.llm?.baseUrl || 'https://api.deepseek.com';
            const defaultModelName = data?.llm?.modelName || 'deepseek-chat';
            const defaultWorkspacePath = data?.workspace?.path || 'output';

            document.getElementById('llmBaseUrl').value = defaultBaseUrl;
            document.getElementById('llmModelName').value = defaultModelName;
            document.getElementById('workspacePath').value = defaultWorkspacePath;

            const sessionLlm = getSessionLlmConfig();
            if (sessionLlm) {
                document.getElementById('llmBaseUrl').value = sessionLlm.baseUrl || defaultBaseUrl;
                document.getElementById('llmModelName').value = sessionLlm.modelName || defaultModelName;
                document.getElementById('llmApiKey').value = sessionLlm.apiKey || '';
            }

            const workspaceConfig = getWorkspacePathConfig();
            if (workspaceConfig?.path) {
                document.getElementById('workspacePath').value = workspaceConfig.path;
            }

            updateLlmStatus(Boolean(sessionLlm && sessionLlm.apiKey));
            validateWorkspace();
        }
    } catch (error) {
        console.error('Failed to load settings:', error);
    }
}

function updateLlmStatus(apiKeyConfigured) {
    const statusEl = document.getElementById('llmStatus');
    if (apiKeyConfigured) {
        statusEl.textContent = 'LLM: configured';
        statusEl.className = 'text-xs px-3 py-1 rounded-full bg-green-100 text-green-700 border border-green-200';
    } else {
        statusEl.textContent = 'LLM: not configured';
        statusEl.className = 'text-xs px-3 py-1 rounded-full llm-alert';
    }
}

function buildTaskLlmConfig() {
    const baseUrl = (document.getElementById('llmBaseUrl')?.value || '').trim();
    const apiKey = (document.getElementById('llmApiKey')?.value || '').trim();
    const modelName = (document.getElementById('llmModelName')?.value || '').trim();
    const sessionLlm = getSessionLlmConfig();
    const resolved = {
        baseUrl: baseUrl || null,
        apiKey: apiKey || (sessionLlm ? sessionLlm.apiKey : null),
        modelName: modelName || null,
        temperature: 0.3,
        maxTokens: 4096,
        timeoutSeconds: 300
    };
    if (!resolved.apiKey) return null;
    setSessionLlmConfig(resolved);
    return resolved;
}

function buildTaskWorkspaceConfig() {
    const workspaceInput = (document.getElementById('workspacePath')?.value || '').trim();
    if (workspaceInput) {
        setWorkspacePathConfig(workspaceInput);
        return { path: workspaceInput };
    }
    const stored = getWorkspacePathConfig();
    return stored && stored.path ? { path: stored.path } : {};
}

async function saveSettings() {
    const sessionLlm = buildTaskLlmConfig();
    if (!sessionLlm) {
        alert('Please provide an LLM API key for this browser session.');
        return;
    }
    const workspacePath = (document.getElementById('workspacePath')?.value || '').trim();
    setWorkspacePathConfig(workspacePath);
    setSessionLlmConfig(sessionLlm);
    updateLlmStatus(true);
    validateWorkspace();
    alert('Saved. LLM config is session-scoped and workspace path is shared across tabs.');
    closeSettings();
}

