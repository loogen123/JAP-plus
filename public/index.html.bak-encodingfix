async function streamClarification(userMessage) {
    if (clarificationStreaming) return;
    const taskLlm = buildTaskLlmConfig();
    if (!taskLlm) {
        addLog('ÚöÖŔ»»', 'ňŻôňëŹń╝ÜŔ»ŁŠť¬ÚůŹšŻ« LLM API Key´╝îŠŚáŠ│ĽŔ┐ŤŔíîÚťÇŠ▒éŠżäŠŞůŃÇé', 'error');
        openSettings();
        return;
    }
    setClarificationStreamingState(true);
    const streamState = { bubble: appendClarificationMessage('assistant', ''), buffer: '', raw: '' };
    const focus = document.getElementById('clarificationFocus').value || 'GENERAL';
    try {
        const response = await fetch(API_BASE + '/api/v1/clarification/stream', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                requirement: pendingRequirement,
                history: clarificationHistory,
                userMessage: userMessage,
                focus: focus,
                llm: taskLlm
            })
        });
        if (!response.ok || !response.body) throw new Error('ňęóňőČšź╗ÚÄ║ŃâąňŻŤŠżÂŔżźŔžŽ: HTTP ' + response.status);
        const reader = response.body.getReader();
        const decoder = new TextDecoder('utf-8');
        while (true) {
            const { value, done } = await reader.read();
            if (done) break;
            handleSseChunk(decoder.decode(value, { stream: true }), streamState);
        }
    } catch (error) {
        streamState.bubble.textContent = 'ŠżäŠŞůňĄ▒Ŕ┤ą: ' + error.message;
        addLog('ÚöÖŔ»»', 'ŠżäŠŞůŔ»ĚŠ▒éňĄ▒Ŕ┤ą: ' + error.message, 'error');
    } finally {
        setClarificationStreamingState(false);
    }
}

