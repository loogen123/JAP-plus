function updateWsStatus(status) {
    const dot = document.getElementById('wsDot');
    const text = document.getElementById('wsStatus');
    dot.className = 'dot ' + status;
    if (status === 'connected') {
        text.textContent = 'WebSocket: connected';
        text.style.color = '#10b981';
    } else if (status === 'connecting') {
        text.textContent = 'WebSocket: connecting...';
        text.style.color = '#f59e0b';
    } else {
        text.textContent = 'WebSocket: disconnected';
        text.style.color = '#64748b';
    }
}

function connectWebSocket(taskId) {
    if (taskId !== undefined && taskId !== null) {
        currentTaskId = taskId;
    }
    if (ws && (ws.readyState === WebSocket.OPEN || ws.readyState === WebSocket.CONNECTING)) {
        return;
    }
    if (wsReconnectTimer) {
        clearTimeout(wsReconnectTimer);
        wsReconnectTimer = null;
    }

    updateWsStatus('connecting');

    const protocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
    ws = new WebSocket(`${protocol}//${window.location.host}/ws`);

    ws.onopen = () => {
        updateWsStatus('connected');
        console.log('Native WebSocket connected');
    };

    ws.onmessage = (messageEvent) => {
        try {
            const event = JSON.parse(messageEvent.data);
            const eventTaskId = event?.data?.taskId ?? null;
            if (eventTaskId !== currentTaskId) {
                return;
            }
            handleStompEvent(event);
        } catch (error) {
            console.error('WebSocket message parse failed:', error);
        }
    };

    ws.onerror = (error) => {
        console.error('WebSocket error:', error);
        updateWsStatus('disconnected');
    };

    ws.onclose = () => {
        updateWsStatus('disconnected');
        ws = null;
        wsReconnectTimer = setTimeout(() => {
            connectWebSocket(currentTaskId);
        }, 3000);
    };
}

function connectWebSocketForTask(taskId) {
    currentTaskId = taskId || null;
    connectWebSocket(currentTaskId);
}

function handleStompEvent(event) {
    console.log('WebSocket event:', event);
    
    switch(event.type) {
        case 'STAGE_CHANGED':
            handleStageChanged(event.data);
            break;
        case 'LOG_ADDED':
            handleLogAdded(event.data);
            break;
        case 'TASK_FINISHED':
            handleTaskFinished(event.data);
            break;
        case 'PROGRESS_UPDATED':
            handleProgressUpdated(event.data);
            break;
