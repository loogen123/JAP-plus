function activateState(stateName) {
    normalizeStateMachineLayout();
    document.querySelectorAll('.state-node').forEach(node => {
        const s = node.dataset.state;
        const isActive = s === stateName;
        const isCompleted = STATE_ORDER.indexOf(s) < STATE_ORDER.indexOf(stateName) && !['MANUAL_INTERVENTION'].includes(s);
        
        node.classList.toggle('active', isActive);
        node.classList.toggle('completed', isCompleted && !isActive);
        
        const rect = node.querySelector('rect');
        if (isActive) {
            rect.setAttribute('fill', '#DBEAFE');
            rect.setAttribute('stroke', '#3B82F6');
            rect.setAttribute('stroke-width', '1.5');
            rect.style.filter = '';
        } else if (isCompleted) {
            rect.setAttribute('fill', '#FFFFFF');
            rect.setAttribute('stroke', '#86EFAC');
            rect.setAttribute('stroke-width', '1');
            rect.style.filter = '';
        } else {
            rect.setAttribute('fill', '#FFFFFF');
            rect.setAttribute('stroke', '#E2E8F0');
            rect.setAttribute('stroke-width', '1');
            rect.style.filter = '';
        }
        
        const texts = node.querySelectorAll('text');
        texts.forEach(t => {
            t.setAttribute('fill', isActive ? '#1E3A8A' : isCompleted ? '#94A3B8' : '#94A3B8');
        });
    });

    document.querySelectorAll('.state-arrow').forEach(arrow => {
        arrow.classList.remove('active');
        arrow.setAttribute('marker-end', 'url(#arrowhead)');
        arrow.setAttribute('stroke', '#94A3B8');
    });

    const label = document.getElementById('currentStateLabel');
    if (label) {
        label.textContent = STATE_LABELS[stateName] || stateName;
        const colorInfo = STATE_COLORS[stateName];
        if (colorInfo) {
            label.className = 'text-xs px-2 py-0.5 rounded-full font-bold mono';
            label.style.backgroundColor = colorInfo.bg + '33';
            label.style.color = colorInfo.text;
            label.style.border = '1px solid ' + colorInfo.bg + '66';
