            border-color: #e5e7eb !important;
            color: #475569 !important;
        }

        #stateMachineSvg text {
            fill: #475569 !important;
            font-size: 18px !important;
            font-weight: 700 !important;
        }

        .state-arrow {
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        .p-4 { padding: 1.5rem !important; }
        .p-3 { padding: 1rem !important; }
        .space-y-2 > :not([hidden]) ~ :not([hidden]) { margin-top: 0.75rem !important; }
        .space-y-3 > :not([hidden]) ~ :not([hidden]) { margin-top: 1rem !important; }
        .space-y-5 > :not([hidden]) ~ :not([hidden]) { margin-top: 1.5rem !important; }
        .gap-4 { gap: 1.5rem !important; }

        .panel-title {
            font-size: 18px !important;
            font-weight: 600 !important;
            color: #0f172a !important;
            letter-spacing: 0;
            text-transform: none !important;
        }

        .field-label {
            font-size: 14px !important;
            font-weight: 500 !important;
            color: #475569 !important;
            text-transform: none !important;
            letter-spacing: 0;
        }

        textarea, input[type="text"], input[type="password"], select {
            font-size: 14px !important;
            line-height: 1.6 !important;
            border-color: #e5e7eb !important;
            box-shadow: none !important;
            background: #f8fafc !important;
        }
        textarea:focus, input[type="text"]:focus, input[type="password"]:focus, select:focus {
            border-color: #3b82f6 !important;
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.16) !important;
            background: #ffffff !important;
        }

        textarea {
            font-size: 15px !important;
            line-height: 1.6 !important;
        }

        .primary-btn {
            background: #ffffff !important;
            border: 1px solid #d1d5db !important;
            color: #111827 !important;
            box-shadow: none !important;
        }
        .primary-btn:hover {
            background: #f9fafb !important;
