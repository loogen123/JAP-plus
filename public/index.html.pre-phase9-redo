        :root {
            --bg-primary: #F8FAFC;
            --bg-secondary: #ffffff;
            --bg-card: #ffffff;
            --border-color: #F1F5F9;
            --accent-blue: #3b82f6;
            --accent-cyan: #06b6d4;
            --accent-green: #22c55e;
            --accent-red: #ef4444;
            --accent-yellow: #f59e0b;
            --accent-purple: #8b5cf6;
            --text-primary: #111827;
            --text-secondary: #374151;
            --text-muted: #6b7280;
