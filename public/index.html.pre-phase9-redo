function openSettings() {
    document.getElementById('settingsPanel').classList.remove('hidden');
}

function closeSettings() {
    document.getElementById('settingsPanel').classList.add('hidden');
}

async function loadSettings() {
    try {
        const response = await fetch(API_BASE + '/api/v1/config');
        if (response.ok) {
            const data = await response.json();
            document.getElementById('llmBaseUrl').value = data.llm.baseUrl;
            document.getElementById('llmModelName').value = data.llm.modelName;
            document.getElementById('workspacePath').value = data.workspace.path;

            const sessionLlm = getSessionLlmConfig();
            if (sessionLlm) {
                document.getElementById('llmBaseUrl').value = sessionLlm.baseUrl || data.llm.baseUrl;
                document.getElementById('llmModelName').value = sessionLlm.modelName || data.llm.modelName;
                document.getElementById('llmApiKey').value = sessionLlm.apiKey || '';
            }
            updateLlmStatus(Boolean(sessionLlm && sessionLlm.apiKey));
        }
    } catch (error) {
        console.error('Failed to load settings:', error);
    }
}

function updateLlmStatus(apiKeyConfigured) {
    const statusEl = document.getElementById('llmStatus');
    if (apiKeyConfigured) {
        statusEl.textContent = 'LLM: configured';
        statusEl.className = 'text-xs px-3 py-1 rounded-full bg-green-100 text-green-700 border border-green-200';
    } else {
        statusEl.textContent = 'LLM: not configured';
        statusEl.className = 'text-xs px-3 py-1 rounded-full llm-alert';
    }
}

function buildTaskLlmConfig() {
    const baseUrl = (document.getElementById('llmBaseUrl')?.value || '').trim();
    const apiKey = (document.getElementById('llmApiKey')?.value || '').trim();
    const modelName = (document.getElementById('llmModelName')?.value || '').trim();
    const sessionLlm = getSessionLlmConfig();
    const resolved = {
        baseUrl: baseUrl || null,
        apiKey: apiKey || (sessionLlm ? sessionLlm.apiKey : null),
        modelName: modelName || null,
        temperature: 0.3,
        maxTokens: 4096,
        timeoutSeconds: 300
    };
    if (!resolved.apiKey) return null;
    setSessionLlmConfig(resolved);
    return resolved;
}

async function saveSettings() {
    const sessionLlm = buildTaskLlmConfig();
    if (!sessionLlm) {
        alert('Please provide an LLM API key for this browser session.');
        return;
    }

    const settings = {
        llm: {
            baseUrl: document.getElementById('llmBaseUrl').value,
            apiKey: '',
            modelName: document.getElementById('llmModelName').value,
            temperature: 0.3,
            maxTokens: 4096,
            timeoutSeconds: 300
        },
        workspace: {
            path: document.getElementById('workspacePath').value
        }
    };

    try {
        const response = await fetch(API_BASE + '/api/v1/config', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(settings)
        });

        if (response.ok) {
            const result = await response.json();
            if (result.success) {
                const statusEl = document.getElementById('workspaceStatus');
                if (result.absolutePath) {
                    statusEl.textContent = 'Saved workspace path: ' + result.absolutePath;
                    statusEl.className = 'text-xs text-green-400 mt-1';
                }
                setSessionLlmConfig(sessionLlm);
                updateLlmStatus(true);
                alert('Saved. LLM config is session-scoped and will not be shared across processes.');
                closeSettings();
            } else {
                alert('Save failed: ' + result.error);
            }
        }
    } catch (error) {
        alert('Save failed: ' + error.message);
    }
}

async function testLlmConnection() {
    const testBtn = document.getElementById('testLlmBtn');
    testBtn.disabled = true;
    testBtn.textContent = 'Testing...';

    const config = {
        baseUrl: document.getElementById('llmBaseUrl').value,
        apiKey: document.getElementById('llmApiKey').value,
        modelName: document.getElementById('llmModelName').value,
        temperature: 0.3,
        maxTokens: 100,
        timeoutSeconds: 30
    };

    try {
        const response = await fetch(API_BASE + '/api/v1/config/llm/test', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(config)
        });

        const result = await response.json();
        if (result.success) {
            testBtn.textContent = 'Connected';
            testBtn.className = 'px-3 py-1.5 rounded-lg text-xs font-medium bg-green-100 text-green-700 border border-green-200';
        } else {
            testBtn.textContent = 'Connection failed';
            testBtn.className = 'px-3 py-1.5 rounded-lg text-xs font-medium bg-rose-100 text-rose-700 border border-rose-200';
        }
    } catch (error) {
        testBtn.textContent = 'Connection failed';
        testBtn.className = 'px-3 py-1.5 rounded-lg text-xs font-medium bg-rose-100 text-rose-700 border border-rose-200';
    }

