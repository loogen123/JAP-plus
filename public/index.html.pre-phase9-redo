            color: #9ca3af !important;
            border-color: #e5e7eb !important;
        }

        #workspaceTopProgressTrack {
            height: 2px;
            background: #f3f4f6;
        }
        #workspaceTopProgressBar {
            height: 2px;
            background: #3b82f6;
            width: 0%;
            transition: width 0.35s ease;
        }

        .llm-alert {
            color: #EF4444 !important;
            background: #FEF2F2 !important;
            border: 1px solid #FCA5A5 !important;
            font-weight: 700 !important;
        }
        .console-tab {
            font-size: 14px;
            font-weight: 500;
            color: #64748b;
            padding: 6px 12px;
            border-radius: 8px;
            border: 1px solid transparent;
            background: transparent;
            transition: all 0.15s ease;
        }
        .console-tab.active {
            color: #1e293b;
            background: #f8fafc;
            border-color: #e2e8f0;
        }
    </style>
</head>
