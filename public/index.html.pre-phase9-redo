    const gs = document.getElementById('globalStatus');
    gs.textContent = stateName === 'COMPLETE' ? '娴佹按绾垮畬鎴? : STATE_LABELS[stateName] || stateName;
    gs.style.color = stateName === 'COMPLETE' ? '#507a63' : stateName === 'BUG_FIX' ? '#8c6666' : '#64748b';

