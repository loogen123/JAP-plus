function renderFileTree(files) {
    const container = document.getElementById('fileTree');
    const folderHint = document.getElementById('folderPathHint');
    if (!files || Object.keys(files).length === 0) {
        container.innerHTML = '<div class="text-[--text-muted] text-center py-4 text-[11px]">鏆傛棤鐢熸垚鐨勬枃浠?/div>';
        if (folderHint) folderHint.textContent = '鏈敓鎴?;
        return;
    }

    const paths = Object.keys(files).sort();
    const folderSet = new Set();
    paths.forEach(path => {
        const normalized = path.replace(/\\/g, '/');
        const parts = normalized.split('/');
        for (let i = 1; i < parts.length; i++) {
            folderSet.add(parts.slice(0, i).join('/'));
        }
    });
    const roots = Array.from(new Set(paths.map(p => p.replace(/\\/g, '/').split('/')[0]))).sort();
    if (folderHint) folderHint.textContent = roots.join(', ');
    roots.forEach(root => {
        if (!expandedFolders.has(root) && selectedTreeFolderPath === '' && selectedTreeFilePath === '') {
            expandedFolders.add(root);
        }
    });

    const tree = { folders: {}, files: [] };
    paths.forEach(path => {
        const normalized = path.replace(/\\/g, '/');
        const parts = normalized.split('/');
        let current = tree;
        for (let i = 0; i < parts.length - 1; i++) {
            const part = parts[i];
            if (!current.folders[part]) current.folders[part] = { folders: {}, files: [] };
            current = current.folders[part];
        }
        current.files.push(normalized);
    });

    function encodePath(path) {
        return encodeURIComponent(path).replace(/'/g, '%27');
    }

    function renderNode(node, parentPath, depth) {
        let html = '';
        const folderNames = Object.keys(node.folders).sort();
        folderNames.forEach(folderName => {
            const fullPath = parentPath ? `${parentPath}/${folderName}` : folderName;
            const expanded = expandedFolders.has(fullPath);
            const selectedClass = selectedTreeFolderPath === fullPath ? ' selected' : '';
            html += `
            <div class="folder-tree-item${selectedClass} flex items-center gap-1.5 px-2 py-1 rounded cursor-pointer mx-1" style="padding-left:${8 + depth * 14}px" onclick="toggleFolderByEncoded('${encodePath(fullPath)}', event)">
                <span class="text-[11px] text-slate-500">${expanded ? '鈻? : '鈻?}</span>
                <span class="text-[11px]">馃搧</span>
                <span class="truncate text-[11px]">${escapeHtml(folderName)}</span>
            </div>`;
            if (expanded) {
                html += renderNode(node.folders[folderName], fullPath, depth + 1);
            }
        });

        node.files.sort().forEach(filePath => {
            const fileName = filePath.split('/').pop();
            const selectedClass = selectedTreeFilePath === filePath ? ' selected' : '';
            html += `
            <div class="file-tree-item${selectedClass} flex items-center gap-2 px-2 py-1 rounded cursor-pointer mx-1" style="padding-left:${10 + depth * 14}px" onclick="selectFileByEncoded('${encodePath(filePath)}', event)">
                ${getFileIcon(fileName)}
                <span class="truncate mono text-[11px]">${escapeHtml(fileName)}</span>
            </div>`;
        });
        return html;
    }

    container.innerHTML = '<div class="px-2 py-1">' + renderNode(tree, '', 0) + '</div>';
}

function getFileIcon(name) {
    if (name.endsWith('.java')) return '<span class="text-[11px] text-amber-700">J</span>';
    if (name.endsWith('.xml')) return '<span class="text-[11px] text-rose-700">X</span>';
    if (name.endsWith('.yml') || name.endsWith('.yaml')) return '<span class="text-[11px] text-cyan-700">Y</span>';
    if (name.endsWith('.md')) return '<span class="text-[11px] text-slate-700">M</span>';
    return '<span class="text-[11px] text-slate-500">F</span>';
}

