async function validateWorkspace() {
    const path = document.getElementById('workspacePath').value;
    const statusEl = document.getElementById('workspaceStatus');

    if (!path) {
        statusEl.textContent = 'Please enter workspace path';
        statusEl.className = 'text-xs text-slate-500 mt-1';
        return;
    }

    try {
        const response = await fetch(API_BASE + '/api/v1/config/workspace/validate', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ path })
        });

        const result = await response.json();
        if (result.valid) {
            statusEl.textContent = 'Valid path: ' + result.absolutePath;
            statusEl.className = 'text-xs text-green-400 mt-1';
        } else {
            statusEl.textContent = 'Invalid: ' + result.error;
            statusEl.className = 'text-xs text-red-400 mt-1';
        }
    } catch (error) {
        statusEl.textContent = 'Validation failed';
        statusEl.className = 'text-xs text-red-400 mt-1';
    }
}

