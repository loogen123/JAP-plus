function connectWebSocket(taskId) {
    updateWsStatus('connecting');
    
    const socket = new SockJS('/ws');
    stompClient = Stomp.over(socket);
    
    stompClient.debug = null;
    
    stompClient.connect({}, function(frame) {
        console.log('STOMP 宸茶繛鎺?', frame);
        updateWsStatus('connected');
        
        if (taskId) {
            stompClient.subscribe('/topic/tasks/' + taskId, function(message) {
                const event = JSON.parse(message.body);
                handleStompEvent(event);
            });
        }
        
    }, function(error) {
        console.error('STOMP 閿欒:', error);
        updateWsStatus('disconnected');
        addLog('WS', 'WebSocket 杩炴帴澶辫触: ' + error, 'error');
        
        setTimeout(function() {
            if (!stompClient || !stompClient.connected) {
                console.log('灏濊瘯 WebSocket 閲嶈繛...');
                connectWebSocket(currentTaskId);
            }
        }, 3000);
    });
}

function connectWebSocketForTask(taskId) {
    if (stompClient && stompClient.connected) {
        stompClient.subscribe('/topic/tasks/' + taskId, function(message) {
            const event = JSON.parse(message.body);
            handleStompEvent(event);
        });
    } else {
        connectWebSocket(taskId);
    }
}

function handleStompEvent(event) {
    console.log('STOMP 浜嬩欢:', event);
    
    switch(event.type) {
        case 'STAGE_CHANGED':
            handleStageChanged(event.data);
            break;
        case 'LOG_ADDED':
            handleLogAdded(event.data);
            break;
        case 'PROGRESS_UPDATED':
            handleProgressUpdated(event.data);
            break;
        case 'FILE_GENERATED':
            handleFileGenerated(event.data);
            break;
        case 'ERROR_DETECTED':
            handleErrorDetected(event.data);
            break;
        case 'FIX_ATTEMPTED':
            handleFixAttempted(event.data);
            break;
        case 'PIPELINE_COMPLETED':
            handlePipelineCompleted(event.data);
            break;
        case 'MANUAL_INTERVENTION_REQUIRED':
            handleManualIntervention(event.data);
            break;
        case 'DESIGN_COMPLETE':
            handleDesignComplete(event.data);
            break;
        case 'BUILD_OUTPUT':
            handleBuildOutput(event.data);
            break;
        case 'PROGRESS_HEARTBEAT':
            handleProgressHeartbeat(event.data);
            break;
        case 'PROTOTYPE_GEN_PROGRESS':
            handlePrototypeProgress(event.data);
            break;
    }
}

