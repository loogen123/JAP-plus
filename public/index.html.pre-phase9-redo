    if (!taskId) return;
    try {
        const resp = await fetch(API_BASE + '/api/v1/tasks/' + encodeURIComponent(taskId) + '/files');
        if (!resp.ok) return;
        const data = await resp.json();
        const flat = [];
        const walk = (nodes) => {
            (nodes || []).forEach(n => {
                if (n && n.children && Array.isArray(n.children) && n.children.length > 0) {
                    walk(n.children);
                } else if (n && n.path) {
                    flat.push(n.path);
                }
            });
        };
        walk(data.files);
        flat.forEach(path => {
            if (!workspaceFiles[path]) {
                workspaceFiles[path] = `// 鐢熸垚鐨勬枃浠? ${path}\n// 鍐呭鍔犺浇涓?..`;
                hydrateWorkspaceFile(path);
            }
        });
        renderFileTree(workspaceFiles);
    } catch (_) {
    }
}

