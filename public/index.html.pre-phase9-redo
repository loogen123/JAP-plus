        }
        .left-sidebar-wrap {
            position: relative;
            width: 300px;
            min-width: 300px;
            height: 100%;
            min-height: 0;
            transition: width 0.28s ease, min-width 0.28s ease;
        }
        .left-sidebar {
            width: 300px;
            min-width: 300px;
            height: 100%;
            min-height: 0;
            transition: width 0.28s ease, min-width 0.28s ease, opacity 0.22s ease;
        }
        .left-sidebar-content {
            height: 100%;
            min-height: 0;
            overflow: hidden;
            transition: opacity 0.2s ease;
        }
        .left-sidebar-scroll {
            flex: 1 1 auto;
            min-height: 0;
            overflow-y: scroll !important;
            overscroll-behavior: contain;
            -webkit-overflow-scrolling: touch;
        }
        .left-sidebar-toggle {
            position: absolute;
            right: -14px;
            top: 50%;
            transform: translateY(-50%);
            width: 28px;
            height: 54px;
            border-radius: 9999px;
            border: 1px solid #dbe3ec;
            background: #ffffff;
            color: #475569;
            font-size: 13px;
            line-height: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 20;
            cursor: pointer;
            box-shadow: 0 6px 16px rgba(15, 23, 42, 0.08);
            transition: all 0.28s ease;
        }
        .left-sidebar-toggle-icon {
            display: inline-block;
            transition: transform 0.28s ease;
        }
        #appShell.left-collapsed .left-sidebar-wrap {
            width: 48px;
            min-width: 48px;
        }
        #appShell.left-collapsed .left-sidebar {
            width: 48px;
            min-width: 48px;
            opacity: 1;
            overflow: hidden;
        }
        #appShell.left-collapsed .left-sidebar-toggle {
            right: 10px;
        }
        #appShell.left-collapsed .left-sidebar-content {
            opacity: 0;
            pointer-events: none;
        }
        #appShell.left-collapsed .left-sidebar-toggle .left-sidebar-toggle-icon {
            transform: rotate(180deg);
        }
        .right-panel {
            width: 360px;
            min-width: 360px;
        }
        .lab-canvas {
            background-color: #F8FAFC;
            background-image: none;
        }
        .bottom-console {
            flex: 1;
            min-height: 0;
        }

        .glow-blue, .glow-green, .glow-red, .glow-yellow { box-shadow: none; }

        .state-node { transition: fill 0.2s ease, stroke 0.2s ease, opacity 0.2s ease; }
        .state-node.active {
            transform: none;
            z-index: 10;
        }
        .state-node.completed { opacity: 1; }

        .state-arrow {
            transition: stroke 0.2s ease;
            stroke-width: 1.5px;
        }
        .state-arrow.active { stroke: #94A3B8; filter: none; }

        .log-entry {
            animation: slideIn 0.3s ease-out;
        }
        @keyframes slideIn {
            from { opacity: 0; transform: translateX(-12px); }
            to { opacity: 1; transform: translateX(0); }
        }

        .pulse-dot {
            animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
        }
        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.4; }
        }

        .typing-indicator span {
            animation: typingBounce 1.4s infinite ease-in-out both;
        }
        .typing-indicator span:nth-child(1) { animation-delay: -0.32s; }
        .typing-indicator span:nth-child(2) { animation-delay: -0.16s; }
        @keyframes typingBounce {
            0%, 80%, 100% { transform: scale(0); }
            40% { transform: scale(1); }
        }

        .file-tree-item { transition: background 0.15s ease, border-color 0.15s ease; border: 1px solid transparent; }
        .file-tree-item:hover { background: #f3f4f6; border-color: #e5e7eb; }
        .file-tree-item.selected { background: #eff6ff; border-color: #bfdbfe; }
        .folder-tree-item { transition: background 0.15s ease, border-color 0.15s ease; border: 1px solid transparent; }
        .folder-tree-item:hover { background: #f3f4f6; border-color: #e5e7eb; }
        .folder-tree-item.selected { background: #f0fdf4; border-color: #bbf7d0; }

        .code-line { transition: background 0.15s ease; }
        .code-line.error { background: rgba(239, 143, 143, 0.2); }
        .code-line.fixed { background: rgba(101, 190, 127, 0.16); }

        .mermaid-container { background: #ffffff; border: 1px solid var(--border-color); border-radius: 12px; padding: 16px; }

        .toggle-switch {
            position: relative; width: 48px; height: 26px;
        }
        .toggle-switch input { opacity: 0; width: 0; height: 0; }
        .toggle-slider {
            position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0;
            background: #d7e6f8; border-radius: 26px; transition: 0.3s;
        }
        .toggle-slider:before {
            content: ""; position: absolute; height: 20px; width: 20px; left: 3px; bottom: 3px;
            background: white; border-radius: 50%; transition: 0.3s;
        }
        input:checked + .toggle-slider { background: var(--accent-red); }
        input:checked + .toggle-slider:before { transform: translateX(22px); }

        .progress-ring { transform: rotate(-90deg); }
        .progress-ring-circle {
            transition: stroke-dashoffset 0.35s;
            transform-origin: 50% 50%;
        }
        
        .tech-chip {
            padding: 8px 10px;
            border-radius: 8px;
            border: 1px solid var(--border-color);
            background: #ffffff;
            cursor: default;
            transition: all 0.2s;
            line-height: 1.35;
        }
        .tech-chip.selected { border-color: #d1d5db; background: #ffffff; }
        .tech-chip:hover:not(.selected) { border-color: #d1d5db; }
        
        .ws-status { display: flex; align-items: center; gap: 6px; }
        .ws-status .dot { width: 8px; height: 8px; border-radius: 50%; }
        .ws-status .dot.connected { background: #22c55e; box-shadow: none; }
        .ws-status .dot.disconnected { background: #ef8f8f; }
        .ws-status .dot.connecting { background: #f2c981; animation: pulse 1s infinite; }
        nav.glass-panel { box-shadow: none; }

        .tech-chip {
            position: relative;
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 10px;
            padding: 10px 10px 10px 16px !important;
        }
        .tech-chip::before {
            content: "";
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 4px;
            border-radius: 10px 0 0 10px;
            background: #cbd5e1;
        }
        .tech-chip[data-tech="jdk25"]::before { background: #a8c8b0; }
        .tech-chip[data-tech="springboot"]::before { background: #9bc5cf; }
        .tech-chip[data-tech="langchain4j"]::before { background: #b9b7d9; }
        .tech-chip[data-tech="mysql"]::before { background: #d9c9a8; }
        .tech-chip.selected {
            background: #ffffff !important;
            border-color: #d5e1ef !important;
            box-shadow: none;
        }

        #logContainer {
            background: #ffffff;
            color: #24292f;
            font-family: 'JetBrains Mono', monospace !important;
            padding: 18px !important;
            font-size: 15px !important;
            line-height: 1.6 !important;
        }

        #buildTerminal {
